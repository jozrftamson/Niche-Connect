{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "^/api/agents/packages$", "dest": "/api/agents-packages" },
    { "src": "^/api/agents/search$", "dest": "/api/agents-search" },
    { "src": "^/api/agents/workflow$", "dest": "/api/agents-workflow" },
    { "src": "^/api/(.*)$", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "^(.*)$", "dest": "/index.html" }
  ]
}
